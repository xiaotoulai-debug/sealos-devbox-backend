{
  "name": "emag-backend",
  "version": "1.0.0",
  "description": "EMAG 跨境电商管理系统 - 后端服务",
  "main": "dist/index.js",
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "scripts": {
    "dev": "node -r ./scripts/preload-file-polyfill.js -r tsx/cjs src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts",
    "migrate:data": "tsx scripts/migrate-data.ts",
    "migrate:emag-region": "tsx scripts/migrate-emag-region.ts",
    "backfill:product-images": "node -r ./scripts/preload-file-polyfill.js -r tsx/cjs scripts/backfill-product-images.ts",
    "force-complete:product-images": "node -r ./scripts/preload-file-polyfill.js -r tsx/cjs scripts/force-complete-product-images.ts",
    "cleanup:placeholder-images": "node -r ./scripts/preload-file-polyfill.js -r tsx/cjs scripts/cleanup-placeholder-images.ts",
    "backfill:product-urls": "node -r ./scripts/preload-file-polyfill.js -r tsx/cjs scripts/backfill-product-urls.ts",
    "inspect:emag-product": "node -r ./scripts/preload-file-polyfill.js -r tsx/cjs scripts/inspect-emag-product-response.ts",
    "sync:platform-orders": "node -r ./scripts/preload-file-polyfill.js -r tsx/cjs scripts/sync-platform-orders.ts",
    "sync:platform-orders:incremental": "node -r ./scripts/preload-file-polyfill.js -r tsx/cjs scripts/sync-platform-orders.ts --incremental"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.1.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "p-limit": "^6.2.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "pg": "^8.20.0",
    "prisma": "^5.22.0",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
}
