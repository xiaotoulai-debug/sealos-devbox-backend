generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// 员工表
model User {
  id           Int        @id @default(autoincrement())
  username     String     @unique
  passwordHash String     @map("password_hash")
  name         String
  avatar       String?
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at")
  roleId       Int        @map("role_id")
  products       Product[]
  fbeShipments   FbeShipment[]
  role           Role       @relation(fields: [roleId], references: [id])

  @@map("users")
}

/// 角色表
model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

/// 权限节点表（树状结构核心）
model Permission {
  id        Int              @id @default(autoincrement())
  code      String           @unique
  name      String
  type      PermissionType
  sortOrder Int              @default(0) @map("sort_order")
  parentId  Int?             @map("parent_id")
  parent    Permission?      @relation("PermissionTree", fields: [parentId], references: [id])
  children  Permission[]     @relation("PermissionTree")
  roles     RolePermission[]

  @@map("permissions")
}

/// 角色-权限 中间表（多对多关联，方便后续扩展字段如 grantedAt）
model RolePermission {
  roleId       Int        @map("role_id")
  permissionId Int        @map("permission_id")
  assignedAt   DateTime   @default(now()) @map("assigned_at")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

/// 产品表（eMAG 选品池）
model Product {
  id                Int            @id @default(autoincrement())
  pnk               String         @unique
  title             String
  brand             String?
  price             Decimal?       @db.Decimal(10, 2)
  tags              String[]
  rating            Decimal?       @db.Decimal(3, 2)
  reviewCount       Int?           @map("review_count")
  category          String?
  categoryL1        String?        @map("category_l1")
  categoryL2        String?        @map("category_l2")
  categoryL3        String?        @map("category_l3")
  categoryL4        String?        @map("category_l4")
  imageUrl          String?        @map("image_url")
  productUrl        String?        @map("product_url")
  costPrice         Decimal?       @map("cost_price") @db.Decimal(10, 2)
  stock             Int            @default(0)
  linkTag           String?        @map("link_tag")
  purchasePrice     Decimal?       @map("purchase_price") @db.Decimal(10, 2)
  purchaseUrl       String?        @map("purchase_url")
  actualWeight      Decimal?       @map("actual_weight") @db.Decimal(10, 3)
  freightCost       Decimal?       @map("freight_cost") @db.Decimal(10, 2)
  fbeFee            Decimal?       @map("fbe_fee") @db.Decimal(10, 2)
  margin            Decimal?       @map("margin") @db.Decimal(6, 2)
  collectedAt       DateTime?      @map("collected_at")
  length            Decimal?       @map("length") @db.Decimal(10, 2)
  width             Decimal?       @map("width") @db.Decimal(10, 2)
  height            Decimal?       @map("height") @db.Decimal(10, 2)
  sku               String?        @unique @map("sku")
  chineseName       String?        @map("chinese_name")
  developer         String?        @map("developer")
  purchaseQuantity  Int?           @map("purchase_quantity")
  purchaseType      String?        @map("purchase_type")
  purchasePeriod    Int?           @map("purchase_period")
  handlingTime      Int            @default(2) @map("handling_time")
  vat               Int            @default(19)
  publishStatus     String         @default("UNPUBLISHED") @map("publish_status")
  externalProductId String?        @map("external_product_id")
  externalSkuId     String?        @map("external_sku_id")     // 1688 specId：32位 MD5 哈希（万邦 spec_id），优先用于下单
  externalSkuIdNum  String?        @map("external_sku_id_num") // 1688 skuId：纯数字，用于 cargoParamList.skuId 兜底
  externalSynced    Boolean        @default(false) @map("external_synced")
  externalOrderId   String?        @map("external_order_id")
  stockActual       Float          @default(0) @map("stock_actual")
  stockInTransit    Float          @default(0) @map("stock_in_transit")
  inTransitQuantity Int            @default(0) @map("in_transit_quantity") // ERP内部FBE在途数量（由发货单状态流转维护）
  sales1d           Int            @default(0) @map("sales_1d")
  sales7d           Int            @default(0) @map("sales_7d")
  sales14d          Int            @default(0) @map("sales_14d")
  sales30d          Int            @default(0) @map("sales_30d")
  status            ProductStatus  @default(PENDING)
  isDeleted         Boolean        @default(false) @map("is_deleted") // 软删除标记（有关联数据时降级使用）
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  ownerId           Int?           @map("owner_id")
  purchaseOrderId   Int?           @map("purchase_order_id")
  owner             User?          @relation(fields: [ownerId], references: [id])
  purchaseOrder     PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  @@index([status, createdAt(sort: Desc)])
  @@index([category])
  @@index([categoryL1, categoryL2, categoryL3, categoryL4])
  @@index([title])
  @@index([status, ownerId, collectedAt(sort: Desc)])
  @@index([purchaseOrderId])
  @@index([sku])
  @@index([externalProductId])
  @@map("products")

  fbeShipmentItems  FbeShipmentItem[]
  inventoryLogs     InventoryLog[]
  warehouseStocks   WarehouseStock[]
}

/// 采购单（主单）
model PurchaseOrder {
  id               Int                   @id @default(autoincrement())
  orderNo          String                @unique @map("order_no")
  operator         String
  totalAmount      Decimal               @map("total_amount") @db.Decimal(12, 2)
  itemCount        Int                   @default(0) @map("item_count")
  status           OrderStatus           @default(PENDING)
  warehouseId      Int?                  @map("warehouse_id")       // 目标入库仓
  remark           String?
  // ── 1688 订单信息（从子单提取上移，主单维度冗余存储便于列表展示）──
  alibabaOrderId   String?               @map("alibaba_order_id")   // 1688 主订单号
  supplierName     String?               @map("supplier_name")      // 供应商名称
  // ── 物流追踪（支持线下采购手动回填）────────────────────────────
  logisticsCompany String?               @map("logistics_company")  // 物流公司（极兔/顺丰等）
  trackingNumber   String?               @map("tracking_number")    // 运单号
  logisticsStatus  String?               @map("logistics_status")   // 最新物流状态文本
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @default(now()) @updatedAt @map("updated_at")
  warehouse        Warehouse?            @relation(fields: [warehouseId], references: [id])
  products         Product[]
  items            PurchaseOrderItem[]

  @@index([createdAt(sort: Desc)])
  @@index([operator])
  @@index([status])
  @@index([warehouseId])
  @@index([alibabaOrderId])
  @@map("purchase_orders")
}

/// 采购子单（一个主单对应多个 1688 卖家子订单）
model PurchaseOrderItem {
  id                  Int           @id @default(autoincrement())
  purchaseOrderId     Int           @map("purchase_order_id")
  offerId             String?       @map("offer_id")           // 1688 商品 offerId（即卖家维度标识）
  productIds          String?       @map("product_ids")        // 关联的本地产品 ID 列表（JSON 数组）
  quantity            Int           @default(1)                // 本批次合计采购数量
  createdAt           DateTime      @default(now()) @map("created_at")
  // ── 1688 子单回填字段（一个 offerId 对应一个 1688 子订单）────
  alibabaOrderId      String?       @map("alibaba_order_id")      // 1688 官方订单号
  alibabaOrderStatus  String?       @map("alibaba_order_status")  // 1688 状态: waitbuyerpay / waitsellersend / success
  alibabaTotalAmount  Decimal?      @map("alibaba_total_amount") @db.Decimal(12, 2) // 1688 实际支付金额（含运费）
  shippingFee         Decimal?      @map("shipping_fee") @db.Decimal(10, 2)         // 1688 运费
  // ── 物流追踪字段 ────────────────────────────────────────────
  logisticsCompany    String?       @map("logistics_company")
  logisticsNo         String?       @map("logistics_no")
  purchaseOrder       PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([alibabaOrderId])
  @@map("purchase_order_items")
}

/// eMAG 多站点区域枚举（RO=罗马尼亚, BG=保加利亚, HU=匈牙利）
enum EmagRegion {
  RO
  BG
  HU
}

/// 店铺授权（eMAG / Shein / Temu / Amazon 等多平台）
model ShopAuthorization {
  id              Int              @id @default(autoincrement())
  platform        String
  shopName        String           @map("shop_name")
  region          EmagRegion?      // eMAG 站点区域 RO/BG/HU，仅 emag 平台使用；null 时按 shopName 推断
  businessModel   String           @default("TRADITIONAL") @map("business_model")
  apiKey          String           @map("api_key")
  apiSecret       String           @map("api_secret")
  accessToken     String?          @map("access_token")
  refreshToken     String?          @map("refresh_token")
  supplierId      String?          @map("supplier_id")
  expiresAt       DateTime?        @map("expires_at")
  status          String           @default("active")
  isSandbox       Boolean          @default(false) @map("is_sandbox")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  createdBy       Int?             @map("created_by")
  storeProducts   StoreProduct[]
  platformOrders  PlatformOrder[]
  fbeShipments    FbeShipment[]

  @@index([platform])
  @@index([status])
  @@index([businessModel])
  @@map("shop_authorizations")
}

/// 平台订单（eMAG order/read 全量同步到本地）
model PlatformOrder {
  id           Int      @id @default(autoincrement())
  shopId       Int      @map("shop_id")
  emagOrderId  BigInt   @map("emag_order_id")
  status       Int
  statusText   String   @map("status_text")
  orderTime    DateTime @map("order_time")
  orderType    Int?     @map("order_type")
  paymentMode  String?  @map("payment_mode")
  total        Decimal  @db.Decimal(12, 2)
  currency     String?  @default("RON")
  customerJson String?  @map("customer_json") @db.Text
  productsJson String?  @map("products_json") @db.Text
  rawJson      String?  @map("raw_json") @db.Text
  syncedAt     DateTime @default(now()) @map("synced_at")
  shop         ShopAuthorization @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, emagOrderId])
  @@index([shopId])
  @@index([shopId, orderTime(sort: Desc)])
  @@map("platform_orders")
}

/// 店铺在售产品（eMAG product_offer/read 同步，与公海 Product 表分离）
model StoreProduct {
  id               Int      @id @default(autoincrement())
  shopId           Int      @map("shop_id")
  pnk              String   // eMAG part_number_key (如 D9MSJJ3BM)
  vendorSku        String?  @map("vendor_sku") // part_number / 供应商 SKU (如 CDX001)
  sku              String?  // eMAG part_number (平台 SKU)
  ean              String?  // eMAG ean 数组取第一个或合并
  emagOfferId      String?  @map("emag_offer_id")
  name             String
  salePrice        Decimal  @map("sale_price") @db.Decimal(10, 2)
  currency         String?  @default("RON") // eMAG 币种，RO=RON, BG=EUR(2026欧元区), HU=HUF
  stock            Int      @default(0)
  status           Int      @default(1) // 1=Active, 0=Inactive
  categoryId       Int?     @map("category_id")
  imageUrl         String?  @map("image_url")
  mainImage        String?  @map("main_image") // images[display_type=1] 主图 URL
  productUrl       String?  @map("product_url") // 前台商品链接，用于爬虫补图
  mappedInventorySku String? @map("mapped_inventory_sku") // 手动绑定的库存 SKU（对应 Product.sku，纯字符串存储，无 FK 约束）
  validationStatus String?  @map("validation_status")
  docErrors        String?  @map("doc_errors") // eMAG 驳回原因 (JSON 或文本)
  rejectionReason  String?  @map("rejection_reason") // 驳回原因（便于展示）
  comprehensiveSales Float    @default(0) @map("comprehensive_sales") // 综合日销 = d7/7*0.3 + d14/14*0.3 + d30/30*0.4
  syncedAt         DateTime @default(now()) @map("synced_at")
  shop         ShopAuthorization @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, pnk])
  @@index([shopId])
  @@index([pnk])
  @@index([vendorSku])
  @@index([shopId, comprehensiveSales(sort: Desc)])
  @@map("store_products")
}

/// 本地库存/SKU 映射表（历史遗留，当前业务"库存 SKU"已迁移至 Product 表管理）
model Inventory {
  id            Int      @id @default(autoincrement())
  sku           String   @unique // 唯一标识，对应 eMAG part_number
  localImage    String?  @map("local_image") // 本地高清图 URL
  purchaseCost  Decimal? @map("purchase_cost") @db.Decimal(10, 2) // 采购单价
  weight        Decimal? @db.Decimal(10, 3) // 重量 (kg)，用于物流
  length        Decimal? @db.Decimal(10, 2) // 长 (cm)
  width         Decimal? @db.Decimal(10, 2) // 宽 (cm)
  height        Decimal? @db.Decimal(10, 2) // 高 (cm)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([sku])
  @@map("inventory")
}

/// 自动同步日志（订单哨兵、产品雷达、库存同步）
model SyncLog {
  id          Int      @id @default(autoincrement())
  syncType    String   @map("sync_type")   // order_sentinel | product_radar | inventory_sync
  updatedCount Int     @default(0) @map("updated_count")
  durationMs  Int      @default(0) @map("duration_ms")
  result      String?  @db.Text            // success | partial | failed
  detail      String?  @db.Text            // JSON 或简要说明
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([syncType])
  @@index([createdAt(sort: Desc)])
  @@map("sync_logs")
}

/// 1688 授权令牌存储
model AlibabaAuth {
  id                    Int       @id @default(autoincrement())
  appKey                String    @map("app_key")
  appSecret             String    @map("app_secret")
  accessToken           String    @map("access_token")
  refreshToken          String    @map("refresh_token")
  expiresAt             DateTime  @map("expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  memberId              String?   @map("member_id")
  aliId                 String?   @map("ali_id")
  loginId               String?   @map("login_id")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@map("alibaba_auth")
}

/// This table has subclasses and requires additional setup for migrations. Visit https://pris.ly/d/table-inheritance for more info.
/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model postgres_log {
  log_time               DateTime? @db.Timestamptz(3)
  user_name              String?
  database_name          String?
  process_id             Int?
  connection_from        String?
  session_id             String
  session_line_num       BigInt
  command_tag            String?
  session_start_time     DateTime? @db.Timestamptz(6)
  virtual_transaction_id String?
  transaction_id         BigInt?
  error_severity         String?
  sql_state_code         String?
  message                String?
  detail                 String?
  hint                   String?
  internal_query         String?
  internal_query_pos     Int?
  context                String?
  query                  String?
  query_pos              Int?
  location               String?
  application_name       String?
  backend_type           String?
  leader_pid             Int?
  query_id               BigInt?

  @@ignore
}

/// 员工账号状态
enum UserStatus {
  ACTIVE
  INACTIVE
}

/// 权限节点类型
enum PermissionType {
  MENU
  BUTTON
  DATA
}

/// 产品状态（公海 or 已入选私有池）
enum ProductStatus {
  PENDING
  SELECTED
  PURCHASING
  ORDERED
}

/// 采购单状态
enum OrderStatus {
  PENDING       // 待下单（内部建单完成，尚未调 1688）
  PLACED        // 已下单/待付款（1688 订单已创建）
  IN_TRANSIT    // 运输中
  RECEIVED      // 已入库
}

/// 库存流水类型
enum InventoryLogType {
  PURCHASE_IN     // 采购入库（本地仓入库，stockActual +）
  FBE_OUT         // FBE 出库（发货至 eMAG 仓，stockActual -）
  MANUAL_ADJUST   // 人工盘点调整（可正可负）
}

/// 库存流水表（进销存核心记录）
model InventoryLog {
  id             Int              @id @default(autoincrement())
  productId      Int              @map("product_id")
  warehouseId    Int?             @map("warehouse_id")      // 关联仓库（多仓架构，老流水可为空）
  type           InventoryLogType
  changeQuantity Float            @map("change_quantity")   // 变动数量（正=入库，负=出库）
  beforeQuantity Float            @map("before_quantity")   // 变动前库存
  afterQuantity  Float            @map("after_quantity")    // 变动后库存
  referenceId    String?          @map("reference_id")      // 关联单据号（采购单ID / FBE发货单ID）
  remark         String?
  createdBy      Int?             @map("created_by")
  createdAt      DateTime         @default(now()) @map("created_at")
  product        Product          @relation(fields: [productId], references: [id])
  warehouse      Warehouse?       @relation(fields: [warehouseId], references: [id])

  @@index([productId])
  @@index([warehouseId])
  @@index([type])
  @@index([createdAt(sort: Desc)])
  @@index([referenceId])
  @@map("inventory_logs")
}

// ══════════════════════════════════════════════════════════════════════
// 多仓架构（Multi-Warehouse）
// ══════════════════════════════════════════════════════════════════════

/// 仓库类型
enum WarehouseType {
  LOCAL        // 自建仓 / 本地仓
  THIRD_PARTY  // 第三方仓 (如海外仓、FBA 等)
}

/// 仓库状态
enum WarehouseStatus {
  ACTIVE    // 启用
  DISABLED  // 停用
}

/// 仓库表
model Warehouse {
  id        Int             @id @default(autoincrement())
  name      String          @unique                         // 仓库名称（如"默认本地主仓"、"eMAG 备货仓"）
  type      WarehouseType   @default(LOCAL)
  status    WarehouseStatus @default(ACTIVE)
  remark    String?
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  stocks    WarehouseStock[]

  inventoryLogs  InventoryLog[]
  fbeShipments   FbeShipment[]
  purchaseOrders PurchaseOrder[]

  @@index([status])
  @@map("warehouses")
}

/// 仓库库存明细（Product × Warehouse 中间表，多仓库存分布）
model WarehouseStock {
  id              Int       @id @default(autoincrement())
  productId       Int       @map("product_id")              // 关联本地产品 (Product.id)
  warehouseId     Int       @map("warehouse_id")            // 关联仓库
  stockQuantity      Float     @default(0) @map("stock_quantity")      // 该仓库中的可用库存
  lockedQuantity     Float     @default(0) @map("locked_quantity")     // 配货锁定数量（预留）
  inTransitQuantity  Float     @default(0) @map("in_transit_quantity") // 采购在途数量（已下单未到仓）
  unitCost           Float     @default(0) @map("unit_cost")           // 单仓移动加权平均成本（含头程公摊）
  sales7             Int       @default(0) @map("sales_7")             // 仓维 7 天销量
  sales14            Int       @default(0) @map("sales_14")            // 仓维 14 天销量
  sales30            Int       @default(0) @map("sales_30")            // 仓维 30 天销量
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  product         Product   @relation(fields: [productId], references: [id])
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@index([warehouseId])
  @@index([productId])
  @@map("warehouse_stocks")
}

/// FBE 发货单状态（4 阶段标准仓储作业状态机）
enum FbeShipmentStatus {
  PENDING     // 待处理（已创建，尚未开始配货）
  ALLOCATING  // 配货中（正在拣货打包，库存尚未扣减）
  SHIPPED     // 已发货（已出库发往 eMAG 仓，stockActual - / inTransitQuantity +）
  ARRIVED     // 已入仓（eMAG 仓收货确认，inTransitQuantity -）
  CANCELLED   // 已取消（PENDING/ALLOCATING 可直接取消；SHIPPED 取消需先退在途库存）
}

/// FBE 发货单（ERP 内部管理 FBE 在途库存）
model FbeShipment {
  id             Int               @id @default(autoincrement())
  shipmentNumber String            @unique @map("shipment_number")
  status         FbeShipmentStatus @default(PENDING)
  shopId             Int?              @map("shop_id")              // 目标店铺（发往哪个 eMAG 店铺仓库）
  warehouseId        Int?              @map("warehouse_id")         // 出库仓库（多仓架构，老数据可为空）
  totalProductValue  Float             @default(0) @map("total_product_value")   // 产品总货值（建单时快照，= Σ qty×purchasePrice）
  overseasFreight    Float             @default(0) @map("overseas_freight")      // 海外头程费用（手动录入）
  domesticFreight    Float             @default(0) @map("domestic_freight")      // 国内运输费用（手动录入）
  remark             String?
  ownerId            Int?              @map("owner_id")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  shop           ShopAuthorization? @relation(fields: [shopId], references: [id])
  warehouse      Warehouse?         @relation(fields: [warehouseId], references: [id])
  owner          User?             @relation(fields: [ownerId], references: [id])
  items          FbeShipmentItem[]

  @@index([status])
  @@index([shopId])
  @@index([warehouseId])
  @@index([ownerId])
  @@index([createdAt(sort: Desc)])
  @@map("fbe_shipments")
}

/// FBE 发货单明细（一单多 SKU）
model FbeShipmentItem {
  id               Int         @id @default(autoincrement())
  shipmentId       Int         @map("shipment_id")
  productId        Int         @map("product_id")
  quantity         Int
  receivedQuantity Int         @default(0) @map("received_quantity")
  shipment         FbeShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  product          Product     @relation(fields: [productId], references: [id])

  @@index([shipmentId])
  @@index([productId])
  @@map("fbe_shipment_items")
}
