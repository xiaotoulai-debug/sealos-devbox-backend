# ============================================================
# EMAG 后端环境变量模板（脱敏，可安全纳入版本控制）
# 使用时：cp .env.example .env  然后填入真实值
# ============================================================

# ── 数据库连接（Sealos / 私有 PostgreSQL）──────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DIRECT_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
SOURCE_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DEST_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME

# ── 服务基础配置 ─────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ── 认证 ─────────────────────────────────────────────────────
JWT_SECRET=your_strong_random_jwt_secret_here
JWT_EXPIRES_IN=7d

# ── 跨域 ─────────────────────────────────────────────────────
# 允许所有来源填 *；或填单个/多个域名（逗号分隔）
CORS_ORIGIN=https://your-frontend-domain.com

# ── 1688 API ─────────────────────────────────────────────────
ALIBABA_APP_KEY=
ALIBABA_APP_SECRET=
ALIBABA_REDIRECT_URI=
ALIBABA_DEFAULT_ADDRESS_ID=

# ── Onebound ─────────────────────────────────────────────────
ONEBOUND_API_KEY=
ONEBOUND_API_SECRET=

# ── eMAG 正向代理 ─────────────────────────────────────────────
EMAG_PROXY_URL=http://PROXY_HOST:PORT
