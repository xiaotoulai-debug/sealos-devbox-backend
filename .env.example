# ============================================================
# EMAG 跨境电商管理系统 - 后端环境变量示例
# 使用前请复制为 .env 并填入真实值。.env 严禁提交至 Git！
# ============================================================

# ---- 数据库 ----
DATABASE_URL="postgresql://user:password@localhost:5432/emag_db?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/emag_db"

# ---- 应用服务 ----
PORT=3001
NODE_ENV=development

# ---- JWT 认证 ----
JWT_SECRET="your-super-secret-jwt-key-replace-in-production"
JWT_EXPIRES_IN="7d"

# ---- 跨域 ----
CORS_ORIGIN="http://localhost:5173"

# ---- 店铺凭证加密密钥 (32 字符, 用于 AES-256 加密 API Key/Secret) ----
SHOP_ENCRYPT_KEY="emag-cross-border-default-key-32"

# ---- 1688 Open Platform (可选) ----
ALIBABA_APP_KEY=""
ALIBABA_APP_SECRET=""
ALIBABA_REDIRECT_URI="http://localhost:3001/api/alibaba/callback"
ALIBABA_DEFAULT_ADDRESS_ID=""

# ---- 万邦 1688 解析 API（采购计划规格关联弹窗必填）----
ONEBOUND_API_KEY=""
ONEBOUND_API_SECRET=""

# ---- 数据迁移 (scripts/migrate-data.ts) ----
# SOURCE_DATABASE_URL  - 源库，默认使用 DIRECT_URL
# DEST_DATABASE_URL    - 目标库，如 postgresql://postgres:密码@dbconn.sealoszh.site:46096/postgres
# SOURCE_DATABASE_URL="postgresql://..."
# DEST_DATABASE_URL="postgresql://postgres:xxx@dbconn.sealoszh.site:46096/postgres"

# ---- eMAG API 正向代理（Sealos 出口 IP 不固定，需经固定 IP 代理发请求）----
# 格式: http://用户名:密码@代理IP:端口
# 留空则不走代理（本地开发或已有固定 IP 时可留空）
EMAG_PROXY_URL=""

# ---- eMAG API 凭证说明 ----
# eMAG 凭证通过「店铺授权」界面录入，存储在 shop_authorizations 表中。
